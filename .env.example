# Remote Claude 飞书客户端配置

# 飞书应用配置（必填）
# 在飞书开发者后台创建应用获取: https://open.feishu.cn/app
FEISHU_APP_ID=cli_xxxxx
FEISHU_APP_SECRET=xxxxx

# 用户白名单（可选）
# 启用后只有白名单中的用户可以使用
ENABLE_USER_WHITELIST=false
ALLOWED_USERS=ou_xxxxx,ou_yyyyy

# 群聊名称前缀（可选，默认「Remote-Claude」）
# 群名格式：{GROUP_NAME_PREFIX}{目录名}-{HH-MM}，如：【Remote-Claude】myapp-14-30
# GROUP_NAME_PREFIX=【Remote-Claude】

# Claude CLI 命令（可选，默认 claude）
# 支持多词命令，如：ccr code、/usr/local/bin/claude
# CLAUDE_COMMAND=claude

# 流式卡片配置（可选）
# 单张卡片最多显示的 block 数量，超限自动冻结并创建新卡片（默认 50）
# MAX_CARD_BLOCKS=50

# lark_client 日志级别（可选，默认 INFO）
# 支持: DEBUG / INFO / WARNING / ERROR
# LARK_LOG_LEVEL=INFO

# server 日志级别（可选，默认 INFO）
# 支持: DEBUG / INFO / WARNING / ERROR
# SERVER_LOG_LEVEL=INFO

# SOCKS 代理兼容（可选）
# 系统有 SOCKS 代理但飞书可直连时，设为 1 绕过代理
# LARK_NO_PROXY=1

# ---- 用户 OAuth 授权（可选）----
# 启用后用户可通过 OAuth 授权，以个人身份调用飞书 API（如发送消息到机器人不在的群）
# ENABLE_USER_AUTH=false
# OAuth 回调服务器端口（默认 8080）
# OAUTH_SERVER_PORT=8080
# OAuth 重定向 URI（需与飞书开放平台应用配置一致，默认 http://localhost:{OAUTH_SERVER_PORT}/oauth/callback）
# OAUTH_REDIRECT_URI=http://localhost:8080/oauth/callback

# ---- 统计（可选）----
# Mixpanel token，用于匿名使用统计。留空则禁用。
# MIXPANEL_TOKEN=your_mixpanel_token

# ---- AI 分析配置（可选）----
# Anthropic API Key（可选，仅作为降级备用）
# 优先使用 Claude 会话分析（零成本），仅在会话不可用时降级到 API
# ANTHROPIC_API_KEY=sk-ant-xxx

